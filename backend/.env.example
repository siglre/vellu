# Скопируйте этот файл в .env и заполните своими значениями

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vellu
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# CORS — адрес фронтенда
CLIENT_URL=http://localhost:5173
